#!/bin/bash
INT="wlan0"
CACHE="/tmp/i3net_cache"

# Pick active interface — any UP external USB wifi adapter (wlx*) takes priority over built-in
IFACE=$INT
for dev in /sys/class/net/wlx*; do
    [ -d "$dev" ] || continue
    if [ "$(cat $dev/operstate 2>/dev/null)" = "up" ]; then
        IFACE=$(basename "$dev")
        break
    fi
done

RX=$(cat /sys/class/net/$IFACE/statistics/rx_bytes 2>/dev/null || echo 0)
TX=$(cat /sys/class/net/$IFACE/statistics/tx_bytes 2>/dev/null || echo 0)
NOW=$(date +%s)

DOWN=0
UP=0
if [ -f "$CACHE" ]; then
    read PREV_IFACE PREV_RX PREV_TX PREV_TIME < "$CACHE"
    DT=$(( NOW - PREV_TIME ))
    if [ "$PREV_IFACE" = "$IFACE" ] && [ "$DT" -gt 0 ]; then
        DOWN=$(( (RX - PREV_RX) / DT ))
        UP=$(( (TX - PREV_TX) / DT ))
    fi
fi
echo "$IFACE $RX $TX $NOW" > "$CACHE"

fmt() {
    local b=$1
    if   [ "$b" -ge 1048576 ]; then printf "%sM" "$(( b / 1048576 ))"
    elif [ "$b" -ge 1024 ];    then printf "%sK" "$(( b / 1024 ))"
    else                            printf "%sB" "$b"
    fi
}

fmtbig() {
    local b=$1
    if   [ "$b" -ge 1073741824 ]; then awk "BEGIN{printf \"%.1fG\", $b/1073741824}"
    elif [ "$b" -ge 1048576 ];    then printf "%sM" "$(( b / 1048576 ))"
    elif [ "$b" -ge 1024 ];       then printf "%sK" "$(( b / 1024 ))"
    else                               printf "%sB" "$b"
    fi
}

IP=$(ip -4 addr show "$IFACE" 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1)
[ -z "$IP" ] && IP="no IP"

NET_ICON=$'\uf1eb'
TEXT="${NET_ICON} $(fmt $DOWN)↓ $(fmt $UP)↑ [${IFACE}]"

L1="${IFACE}  ${IP}"
L2="↓ $(fmt $DOWN)/s   ↑ $(fmt $UP)/s"
L3="Total RX: $(fmtbig $RX)   TX: $(fmtbig $TX)"

printf '{"text":"%s","tooltip":"%s\\n%s\\n%s"}\n' "$TEXT" "$L1" "$L2" "$L3"
